<style>
  :root {
    --bg:          #F3F7F4;
    --surface:     #FFFFFF;
    --surface-2:   #F8FBF9;
    --border:      #DDE8E1;
    --text:        #0F1F16;
    --text-2:      #4A6358;
    --text-3:      #7E9E90;
    --green:       #2EAA6E;
    --green-dark:  #12281E;
    --green-mid:   #1B7A4E;
    --green-tint:  #E6F5EE;
    --amber:       #92400E;
    --amber-bg:    #FFFBEB;
    --amber-border:#FDE68A;
    --radius-sm:   10px;
    --radius-md:   16px;
    --radius-lg:   22px;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg:         #0B1810;
      --surface:    #152219;
      --surface-2:  #1A2D20;
      --border:     #243D2C;
      --text:       #EAF2EC;
      --text-2:     #8BB89C;
      --text-3:     #567060;
      --green:      #3DC47E;
      --green-dark: #0A1410;
      --green-mid:  #2EAA6E;
      --green-tint: #1A3526;
      --amber:      #FCD34D;
      --amber-bg:   #1C1400;
      --amber-border:#78500A;
    }
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Header ── */
  header {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 0 24px;
  }
  .header-inner {
    max-width: 680px;
    margin: 0 auto;
    height: 60px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .logo-mark {
    width: 34px;
    height: 34px;
    border-radius: 9px;
    background: #12281E;
    overflow: hidden;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px;
  }
  .logo-mark img { width: 100%; height: 100%; object-fit: contain; }
  .logo-mark svg { width: 100%; height: 100%; }
  .logo-name {
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.3px;
    color: var(--text);
  }
  .logo-name span { color: var(--green); }

  /* ── Main layout ── */
  main {
    max-width: 680px;
    margin: 0 auto;
    padding: 36px 20px 60px;
  }

  /* ── Hero ── */
  .hero {
    margin-bottom: 32px;
  }
  .hero h1 {
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.5px;
    line-height: 1.2;
    margin-bottom: 8px;
  }
  .hero-meta {
    font-size: 13px;
    color: var(--text-3);
  }

  /* ── Cards ── */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: 16px;
  }
  .card-header {
    padding: 18px 22px 14px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .card-header-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: var(--green-tint);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .card-header-icon svg {
    width: 18px;
    height: 18px;
    stroke: var(--green);
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .card-header h2 {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.2px;
  }
  .card-body {
    padding: 18px 22px 20px;
  }
  .card-body p {
    font-size: 14px;
    color: var(--text-2);
    line-height: 1.7;
    margin-bottom: 12px;
  }
  .card-body p:last-child { margin-bottom: 0; }

  /* ── Data table ── */
  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13.5px;
  }
  .data-table th {
    text-align: left;
    padding: 10px 14px;
    background: var(--surface-2);
    color: var(--text-3);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 1px solid var(--border);
  }
  .data-table td {
    padding: 11px 14px;
    color: var(--text-2);
    border-bottom: 1px solid var(--border);
    line-height: 1.5;
    vertical-align: top;
  }
  .data-table tr:last-child td { border-bottom: none; }
  .data-table td:first-child {
    color: var(--text);
    font-weight: 500;
    white-space: nowrap;
  }

  /* ── Service list ── */
  .service-list {
    list-style: none;
    padding: 0;
  }
  .service-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
    font-size: 14px;
    color: var(--text-2);
    line-height: 1.5;
  }
  .service-list li:last-child { border-bottom: none; }
  .service-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green);
    flex-shrink: 0;
    margin-top: 6px;
  }
  .service-list strong { color: var(--text); font-weight: 600; }

  /* ── Rights list ── */
  .rights-list {
    list-style: none;
    padding: 0;
  }
  .rights-list li {
    display: flex;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
    font-size: 14px;
    color: var(--text-2);
    line-height: 1.5;
    align-items: flex-start;
  }
  .rights-list li:last-child { border-bottom: none; }
  .rights-check {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--green-tint);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .rights-check svg {
    width: 11px;
    height: 11px;
    stroke: var(--green);
    fill: none;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  @media (prefers-color-scheme: dark) {
    .rights-check svg { stroke: var(--green); }
  }
  .rights-list strong { color: var(--text); font-weight: 600; }

  /* ── Deletion steps ── */
  .steps {
    list-style: none;
    counter-reset: steps;
    padding: 4px 22px 18px;
  }
  .steps li {
    counter-increment: steps;
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 13px 0;
    border-bottom: 1px solid var(--border);
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-2);
  }
  .steps li:last-child { border-bottom: none; }
  .steps li::before {
    content: counter(steps);
    min-width: 26px;
    height: 26px;
    background: var(--green-tint);
    color: var(--green-mid);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
  }
  @media (prefers-color-scheme: dark) {
    .steps li::before { color: var(--green); }
  }
  .steps li strong { color: var(--text); font-weight: 600; }

  /* ── Divider ── */
  .divider {
    display: flex;
    align-items: center;
    gap: 14px;
    margin: 4px 22px 0;
  }
  .divider::before, .divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }
  .divider span {
    font-size: 12px;
    color: var(--text-3);
    font-weight: 500;
    letter-spacing: 0.3px;
  }

  /* ── Email fallback ── */
  .email-section {
    padding: 16px 22px 20px;
  }
  .email-section p {
    font-size: 13.5px;
    color: var(--text-2);
    line-height: 1.65;
    margin-bottom: 14px;
  }
  .mail-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--green-tint);
    color: var(--green-mid);
    border: 1px solid var(--green);
    border-radius: var(--radius-sm);
    padding: 9px 16px;
    font-size: 13.5px;
    font-weight: 600;
    text-decoration: none;
    margin-bottom: 10px;
  }
  @media (prefers-color-scheme: dark) {
    .mail-btn { color: var(--green); }
  }
  .email-note {
    font-size: 12px;
    color: var(--text-3);
    line-height: 1.6;
  }

  /* ── Contact card ── */
  .contact-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 22px;
  }
  .contact-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: var(--green-tint);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .contact-icon svg {
    width: 17px;
    height: 17px;
    stroke: var(--green);
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .contact-detail {
    font-size: 14px;
    color: var(--text-2);
    line-height: 1.4;
  }
  .contact-detail a {
    color: var(--green);
    text-decoration: none;
    font-weight: 600;
  }

  /* ── Links ── */
  a { color: var(--green); }

  /* ── Footer ── */
  footer {
    text-align: center;
    font-size: 12px;
    color: var(--text-3);
    padding: 0 20px 40px;
    line-height: 1.8;
  }
  footer a { color: var(--text-3); text-decoration: underline; }
</style>
